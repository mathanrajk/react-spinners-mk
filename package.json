{
  "name": "react-spinners-mk",
  "version": "1.0.0",
  "description": "A collection of simple, customizable, and lightweight loading spinners for React applications.",
  "type": "module",
  "main": "dist/react-spinners-mk.umd.cjs",
  "module": "dist/react-spinners-mk.js",
  "types": "dist/index.d.ts",
